{
  "description": "Safety hooks for remote-control plugin — warns before running destructive remote commands",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-destructive-remote.sh"
          }
        ]
      }
    ]
  }
}
